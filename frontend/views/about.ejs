<%- include('partials/header', { title: 'About Us', currentPath: '/about' }) %>

<main class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
  <h1 data-aos="fade-down" style="font-size: 2.5rem; text-align: center; margin-bottom: 3rem;">About BMMSWC</h1>
  
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; margin-bottom:4rem;">
    <section data-aos="fade-right">
      <h2 style="display:flex; align-items:center; gap:0.5rem;"><i data-lucide="clock" style="color:var(--accent)"></i> Our History</h2>
      <p style="font-size:1.1rem; color:var(--text-muted)">Established in 1985, the Bangladesh Manipuri Muslim Student Welfare Association (BMMSWC) is the premier non-political welfare organization dedicated to the Manipuri Muslim student community in Bangladesh. For over four decades, we have served as a unified platform for students to connect, grow, and lead.</p>
    </section>

    <section data-aos="fade-left">
      <h2 style="display:flex; align-items:center; gap:0.5rem;"><i data-lucide="target" style="color:var(--accent)"></i> Mission & Vision</h2>
      <p style="font-size:1.1rem; color:var(--text-muted)"><strong>Mission:</strong> Our mission is to empower Manipuri Muslim students by fostering a spirit of unity and cooperation. We are committed to nurturing future leaders and driving academic excellence through comprehensive educational development initiatives.</p>
      <p style="font-size:1.1rem; color:var(--text-muted)"><strong>Vision:</strong>We strive to create a society where our youth are educationally advanced and socially responsible. Central to our work is the preservation of our unique cultural identity, ensuring that our heritage remains vibrant while we contribute meaningfully to the progress of the nation.</p>
    </section>
  </div>

  <section data-aos="fade-up">
  <h2 style="text-align: center; margin-bottom: 2rem;">Executive Committee</h2>

  <div class="cards" style="display: flex; justify-content: center; flex-wrap: wrap; gap: 2rem; margin-bottom: 3rem;">
    
    <article class="card person" data-aos="fade-up" data-aos-delay="100">
      <img src="/assets/images/musfiq.jpg?auto=format&fit=crop&w=400&q=80" alt="President">
      <h3>ASM Musfiqur Rahman</h3>
      <p class="muted">President</p>
    </article>

    <article class="card person" data-aos="fade-up" data-aos-delay="100">
      <img src="/assets/images/toiyob1.jpg?auto=format&fit=crop&w=400&q=80" alt="Secretary">
      <h3>Toiyob Ali</h3>
      <p class="muted">General Secretary</p>
    </article>

  </div>

  <div class="cards" style="display: flex; justify-content: center; flex-wrap: wrap; gap: 2rem;">

    <article class="card person" data-aos="fade-up" data-aos-delay="300">
      <img src="/assets/images/rofiqul.jpg?auto=format&fit=crop&w=400&q=80" alt="Treasurer">
      <h3>Rofiqul Islam</h3>
      <p class="muted">Treasurer</p>
    </article>

    <article class="card person" data-aos="fade-up" data-aos-delay="400">
      <img src="/assets/images/afiq.jpg?auto=format&fit=crop&w=400&q=80" alt="Organizing">
      <h3>Afikul Islam</h3>
      <p class="muted">Organizing Secretary</p>
    </article>

    <article class="card person" data-aos="fade-up" data-aos-delay="500">
      <img src="/assets/images/vice_president.jpg?auto=format&fit=crop&w=400&q=80" alt="Vice President">
      <h3>Israt Akter</h3>
      <p class="muted">Vice President</p>
    </article>

    <article class="card person" data-aos="fade-up" data-aos-delay="600">
      <img src="/assets/images/jointsec.jpg?auto=format&fit=crop&w=400&q=80" alt="Joint Secretary">
      <h3>Merina Begum</h3>
      <p class="muted">Joint General Secretary</p>
    </article>

  </div>
</section>
</main>

