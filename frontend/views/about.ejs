<%- include('partials/header', { title: 'About Us', currentPath: '/about' }) %>

<main class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
  <h1 data-aos="fade-down" style="font-size: 2.5rem; text-align: center; margin-bottom: 3rem;">About MSWA</h1>
  
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; margin-bottom:4rem;">
    <section data-aos="fade-right">
      <h2 style="display:flex; align-items:center; gap:0.5rem;"><i data-lucide="clock" style="color:var(--accent)"></i> Our History</h2>
      <p style="font-size:1.1rem; color:var(--text-muted)">The Monipuri Student Welfare Association was founded to create an inseparable bond among all former and current students. Starting from a humble gathering in the early 2000s, it has grown into a powerful network spanning various fields including technology, medicine, education, and arts.</p>
    </section>

    <section data-aos="fade-left">
      <h2 style="display:flex; align-items:center; gap:0.5rem;"><i data-lucide="target" style="color:var(--accent)"></i> Mission & Vision</h2>
      <p style="font-size:1.1rem; color:var(--text-muted)"><strong>Mission:</strong> To foster lifelong connections between alumni and our alma mater while facilitating support systems for undergraduates.</p>
      <p style="font-size:1.1rem; color:var(--text-muted)"><strong>Vision:</strong> A community where every student realizes their fullest potential, empowered by an internationally connected alumni family.</p>
    </section>
  </div>

  <section data-aos="fade-up">
    <h2 style="text-align: center; margin-bottom: 2rem;">Executive Committee</h2>
    <div class="cards">
      <article class="card person" data-aos="fade-up" data-aos-delay="100">
        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=400&q=80" alt="President">
        <h3>Sarah J. Rahman</h3>
        <p class="muted">President</p>
      </article>
      <article class="card person" data-aos="fade-up" data-aos-delay="200">
        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&w=400&q=80" alt="Secretary">
        <h3>Michael T. Smith</h3>
        <p class="muted">General Secretary</p>
      </article>
      <article class="card person" data-aos="fade-up" data-aos-delay="300">
        <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&w=400&q=80" alt="Treasurer">
        <h3>Dr. Anika Hossain</h3>
        <p class="muted">Treasurer</p>
      </article>
    </div>
  </section>
</main>

<%- include('partials/footer') %>