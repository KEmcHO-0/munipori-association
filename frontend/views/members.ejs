<%- include('partials/header', { title: 'Members', currentPath: '/members' }) %>

<main class="container" style="padding-top:4rem;">
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start;">
    
    <div data-aos="fade-right">
      <h1>Join the Alumni Directory</h1>
      <p style="font-size:1.1rem; color:var(--text-muted); margin-bottom:2rem;">Register quickly to unlock networking capabilities, receive priority event invitations, and stay updated with the Monipuri community.</p>

      <form id="register-form" class="form" style="max-width:100%; box-shadow:var(--shadow-lg);">
        <label>Full Name 
          <input name="name" type="text" placeholder="John Doe" required>
        </label>
        <label>Email Address 
          <input name="email" type="email" placeholder="john@example.com" required>
        </label>
        <label>Graduation Year 
          <input name="year" type="number" placeholder="2020" min="1950" max="<%= new Date().getFullYear() + 4 %>">
        </label>
        <label>Current Profession / Message
          <textarea name="message" placeholder="I am currently working as a..."></textarea>
        </label>
        <button class="btn primary" type="submit" style="margin-top:1rem; width:100%;"><i data-lucide="user-plus" style="margin-right:8px;"></i> Complete Registration</button>
      </form>
    </div>

    <div data-aos="fade-left">
      <h2>Recent Network Joins</h2>
      <p class="muted">Check out who recently joined our growing alumni database.</p>
      
      <div id="member-list" class="cards" style="grid-template-columns:1fr; gap:1rem; margin-top:2rem;">
        <div class="card" style="display:flex; align-items:center; gap:1rem; padding:1rem;">
          <div style="width:50px; height:50px; background:var(--primary); color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold;">AJ</div>
          <div>
            <h4 style="margin:0;">Alif J.</h4>
            <p class="muted" style="margin:0; font-size:0.9rem;">Class of 2018</p>
          </div>
        </div>
        <div class="card" style="display:flex; align-items:center; gap:1rem; padding:1rem;">
          <div style="width:50px; height:50px; background:var(--accent); color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold;">MR</div>
          <div>
            <h4 style="margin:0;">Maria R.</h4>
            <p class="muted" style="margin:0; font-size:0.9rem;">Class of 2021</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('partials/footer') %>