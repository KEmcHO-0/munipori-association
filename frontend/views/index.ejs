<%- include('partials/header', { title: 'Home', currentPath: '/' }) %>

<main>
  <section class="hero">
    <div class="hero-inner container">
      <div class="hero-text" data-aos="fade-right">
        <h1>Transforming Our Community Together</h1>
        <p class="slogan">Strengthening bonds between currents students and esteemed alumni of the Bangladesh Manipuri Student Welfare Council.</p>
        <div style="display:flex; gap:1rem; margin-top:2rem;">
          <a class="btn outline" href="/about">Learn More</a>
        </div>
      </div>
      <div class="hero-image" data-aos="fade-left">
        <!-- Replaced with a more professional graduation/school image -->
        <img src="/assets/images/ok.jpg?auto=format&fit=crop&w=1200&q=80" alt="Students walking together">
      </div>
    </div>
  </section>

  <section class="intro container" data-aos="fade-up">
    <h2>About the Association</h2>
    <p style="font-size:1.15rem; color: #475569; max-width:800px;">The Bangladesh Manipuri Muslim Student Welfare Council (BMMSWC) serves as a vital bridge connecting current students and alumni. We facilitate a dynamic network for sharing news, celebrating milestones, and unlocking career opportunities.</p>
  </section>

  <section class="news container">
    <h2 data-aos="fade-up">Latest Announcements</h2>
    <div class="cards" id="news-list">
      <article class="card" data-aos="fade-up" data-aos-delay="100">
        <i data-lucide="megaphone" style="color:var(--accent); margin-bottom:1rem; width:32px; height:32px;"></i>
        <h3>Annual Alumni Meet <%= new Date().getFullYear() %></h3>
        <p class="muted">Join us for networking, mentorship panels, and celebrations. Registration opens next month.</p>
        <a href="/events" class="btn outline" style="margin-top:1rem; padding:0.5rem 1rem;">Read more</a>
      </article>
    </div>
  </section>

</main>

<%- include('partials/footer') %>