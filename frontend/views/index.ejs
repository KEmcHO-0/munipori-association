<%- include('partials/header', { title: 'Home', currentPath: '/' }) %>

<main>
  <section class="hero">
    <div class="hero-inner container">
      <div class="hero-text" data-aos="fade-right">
        <h1>Transforming Our Community Together</h1>
        <p class="slogan">Strengthening bonds between currents students and esteemed alumni of the Monipuri Student Welfare Association.</p>
        <div style="display:flex; gap:1rem; margin-top:2rem;">
          <a class="btn primary" href="/members">Join the Network <i data-lucide="arrow-right" style="width:18px; margin-left:8px; vertical-align:text-bottom;"></i></a>
          <a class="btn outline" href="/about">Learn More</a>
        </div>
      </div>
      <div class="hero-image" data-aos="fade-left">
        <!-- Replaced with a more professional graduation/school image -->
        <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1200&q=80" alt="Students walking together">
      </div>
    </div>
  </section>

  <section class="intro container" data-aos="fade-up">
    <h2>About the Association</h2>
    <p style="font-size:1.15rem; color: #475569; max-width:800px;">The Monipuri Student Welfare Association (MSWA) connects current students and alumni to share news, events, and career opportunities. We foster a supportive network and raise funds to support school programs and career advancement workshops.</p>
  </section>

  <section class="news container">
    <h2 data-aos="fade-up">Latest Announcements</h2>
    <div class="cards" id="news-list">
      <article class="card" data-aos="fade-up" data-aos-delay="100">
        <i data-lucide="megaphone" style="color:var(--accent); margin-bottom:1rem; width:32px; height:32px;"></i>
        <h3>Annual Alumni Meet <%= new Date().getFullYear() %></h3>
        <p class="muted">Join us for networking, mentorship panels, and celebrations. Registration opens next month.</p>
        <a href="/events" class="btn outline" style="margin-top:1rem; padding:0.5rem 1rem;">Read more</a>
      </article>
      <article class="card" data-aos="fade-up" data-aos-delay="200">
        <i data-lucide="award" style="color:var(--accent); margin-bottom:1rem; width:32px; height:32px;"></i>
        <h3>Student Achievement Awards</h3>
        <p class="muted">Recognising phenomenal achievements across academics and sports for the Fall semester.</p>
        <a href="/news" class="btn outline" style="margin-top:1rem; padding:0.5rem 1rem;">View winners</a>
      </article>
    </div>
  </section>

</main>

<%- include('partials/footer') %>