<%- include('partials/header', { title: 'Admin Dashboard', currentPath: '/admin/dashboard' }) %>

<main class="container" style="padding-top: 4rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1>Admin Dashboard</h1>
        <a href="/admin/logout" class="btn outline" style="color: #dc2626; border-color: #dc2626;">Logout</a>
    </div>

    <section>
        <h2>Manage Events</h2>
        
        <div style="background: #f8fafc; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 3rem;">
            <h3>Add New Event</h3>
            <form id="addEventForm" style="display: grid; gap: 1rem; grid-template-columns: 1fr 1fr;">
                <div class="form-group" style="grid-column: span 2;">
                    <label for="title">Event Title</label>
                    <input type="text" id="title" name="title" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group">
                    <label for="date">Date</label>
                    <input type="text" id="date" name="date" placeholder="e.g. October 20, 2026" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group">
                    <label for="time">Time</label>
                    <input type="text" id="time" name="time" placeholder="e.g. 7:00 PM" style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label for="location">Location</label>
                    <input type="text" id="location" name="location" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label for="attachment">Attachment (Photo or PDF)</label>
                    <input type="file" id="attachment" name="attachment" accept="image/*,.pdf" style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="3" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px; font-family: inherit;"></textarea>
                </div>
                <div style="grid-column: span 2; text-align: right;">
                    <button type="submit" class="btn primary">Add Event</button>
                </div>
            </form>
        </div>

        <h3>All Events</h3>
        <table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
            <thead>
                <tr style="background: #f1f5f9; text-align: left;">
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Title</th>
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Date & Time</th>
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Location</th>
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(events && events.length > 0) { %>
                    <% events.forEach(event => { %>
                        <tr>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0; font-weight: 500;">
                                <%= event.title %>
                                <% if(event.attachment) { %>
                                    <br><a href="<%= event.attachment %>" target="_blank" style="font-size: 0.8rem; color: #3b82f6;">[View Attachment]</a>
                                <% } %>
                            </td>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0;"><%= event.date %> <br><small class="muted"><%= event.time %></small></td>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0;"><%= event.location %></td>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0;">
                                <button class="delete-event-btn" data-id="<%= event.id %>" style="background: #ef4444; color: white; border: none; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer;">Delete</button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" style="padding: 1rem; border-bottom: 1px solid #e2e8f0; text-align: center; color: #64748b;">No events found ...</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>

    <!-- ALUMNI SECTION -->
    <section style="margin-top: 4rem;">
        <h2>Manage Alumni</h2>
        
        <div style="background: #f8fafc; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 3rem;">
            <h3>Add New Alumni</h3>
            <form id="addAlumniForm" style="display: grid; gap: 1rem; grid-template-columns: 1fr 1fr;">
                <div class="form-group">
                    <label for="name">Full Name</label>
                    <input type="text" id="name" name="name" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group">
                    <label for="batch">Batch / Graduation Year</label>
                    <input type="text" id="batch" name="batch" placeholder="e.g. 2018" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group">
                    <label for="profession">Current Profession</label>
                    <input type="text" id="profession" name="profession" placeholder="e.g. Software Engineer" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group">
                    <label for="image">Profile Image (optional)</label>
                    <input type="file" id="image" name="image" accept="image/*" style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div style="grid-column: span 2; text-align: right;">
                    <button type="submit" class="btn primary">Add Alumni</button>
                </div>
            </form>
        </div>

        <h3>All Alumni</h3>
        <table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
            <thead>
                <tr style="background: #f1f5f9; text-align: left;">
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1; width: 60px;">Image</th>
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Name</th>
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Batch</th>
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Profession</th>
                    <th style="padding: 1rem; border-bottom: 2px solid #cbd5e1;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(alumniList && alumniList.length > 0) { %>
                    <% alumniList.forEach(alumni => { %>
                        <tr>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0;">
                                <img src="<%= alumni.image %>" alt="<%= alumni.name %>" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                            </td>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0; font-weight: 500;"><%= alumni.name %></td>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0;"><%= alumni.batch %></td>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0;"><%= alumni.profession %></td>
                            <td style="padding: 1rem; border-bottom: 1px solid #e2e8f0;">
                                <button class="delete-alumni-btn" data-id="<%= alumni.id %>" style="background: #ef4444; color: white; border: none; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer;">Delete</button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" style="padding: 1rem; border-bottom: 1px solid #e2e8f0; text-align: center; color: #64748b;">No alumni found ...</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>

    <!-- GALLERY SECTION -->
    <section style="margin-top: 4rem; padding-bottom: 4rem;">
        <h2>Manage Gallery</h2>
        
        <div style="background: #f8fafc; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 3rem;">
            <h3>Add New Gallery Image</h3>
            <form id="addGalleryForm" style="display: grid; gap: 1rem; grid-template-columns: 1fr 1fr;">
                <div class="form-group" style="grid-column: span 2;">
                    <label for="galleryTitle">Image Title/Caption</label>
                    <input type="text" id="galleryTitle" name="title" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label for="galleryImage">Image File (Required)</label>
                    <input type="file" id="galleryImage" name="image" accept="image/*" required style="width: 100%; padding: 0.75rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>
                <div style="grid-column: span 2; text-align: right;">
                    <button type="submit" class="btn primary">Upload Image</button>
                </div>
            </form>
        </div>

        <h3>All Gallery Items</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 1rem;">
            <% if(gallery && gallery.length > 0) { %>
                <% gallery.forEach(item => { %>
                    <div style="border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; background: white;">
                        <img src="<%= item.image %>" alt="<%= item.title %>" style="width: 100%; height: 150px; object-fit: cover;">
                        <div style="padding: 1rem; text-align: center;">
                            <h4 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= item.title %></h4>
                            <button class="delete-gallery-btn" data-id="<%= item.id %>" style="width: 100%; background: #ef4444; color: white; border: none; padding: 0.4rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem;">Delete</button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="grid-column: 1 / -1; text-align: center; color: #64748b; padding: 2rem;">No gallery images found...</p>
            <% } %>
        </div>
    </section>
</main>

<script>
    document.getElementById('addEventForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formElement = document.getElementById('addEventForm');
        const formData = new FormData(formElement);

        try {
            const res = await fetch('/admin/api/events', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if(data.ok) {
                Swal.fire({ title: 'Success', text: 'Event added!', icon: 'success' }).then(() => {
                    window.location.reload();
                });
            }
        } catch(err) {
            Swal.fire({ title: 'Error', text: 'Could not add event', icon: 'error' });
        }
    });

    document.querySelectorAll('.delete-event-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const id = e.target.getAttribute('data-id');
            if(confirm('Are you sure you want to delete this event?')) {
                try {
                    const res = await fetch(`/admin/api/events/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    if(data.ok) {
                        window.location.reload();
                    }
                } catch(err) {
                    Swal.fire({ title: 'Error', text: 'Could not delete event', icon: 'error' });
                }
            }
        });
    });

    // Add Alumni Form Submit
    document.getElementById('addAlumniForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formElement = document.getElementById('addAlumniForm');
        const formData = new FormData(formElement);

        try {
            const res = await fetch('/admin/api/alumni', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if(data.ok) {
                Swal.fire({ title: 'Success', text: 'Alumni added!', icon: 'success' }).then(() => {
                    window.location.reload();
                });
            }
        } catch(err) {
            Swal.fire({ title: 'Error', text: 'Could not add alumni', icon: 'error' });
        }
    });

    // Delete Alumni
    document.querySelectorAll('.delete-alumni-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const id = e.target.getAttribute('data-id');
            if(confirm('Are you sure you want to delete this alumni record?')) {
                try {
                    const res = await fetch(`/admin/api/alumni/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    if(data.ok) {
                        window.location.reload();
                    }
                } catch(err) {
                    Swal.fire({ title: 'Error', text: 'Could not delete alumni', icon: 'error' });
                }
            }
        });
    });

    // Add Gallery Image Submit
    document.getElementById('addGalleryForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formElement = document.getElementById('addGalleryForm');
        const formData = new FormData(formElement);

        try {
            const res = await fetch('/admin/api/gallery', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if(data.ok) {
                Swal.fire({ title: 'Success', text: 'Image added!', icon: 'success' }).then(() => {
                    window.location.reload();
                });
            } else {
                Swal.fire({ title: 'Error', text: data.message || 'Could not add image', icon: 'error' });
            }
        } catch(err) {
            Swal.fire({ title: 'Error', text: 'Could not add image', icon: 'error' });
        }
    });

    // Delete Gallery Image
    document.querySelectorAll('.delete-gallery-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const id = e.target.getAttribute('data-id');
            if(confirm('Are you sure you want to delete this image?')) {
                try {
                    const res = await fetch(`/admin/api/gallery/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    if(data.ok) {
                        window.location.reload();
                    }
                } catch(err) {
                    Swal.fire({ title: 'Error', text: 'Could not delete image', icon: 'error' });
                }
            }
        });
    });
</script>

<%- include('partials/footer') %>