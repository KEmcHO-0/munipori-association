<%- include('partials/header', { title: 'Gallery', currentPath: '/gallery' }) %>

<main class="container" style="padding-top:4rem; padding-bottom: 4rem;">
  <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom: 2rem;">
    <h1 data-aos="fade-right" style="margin:0;">Photo Gallery</h1>
  </div>

  <div class="cards" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
    <% if (gallery && gallery.length > 0) { %>
      <% gallery.forEach(item => { %>
        <article class="card" data-aos="fade-up" style="overflow: hidden; border-radius: var(--radius); border: 1px solid var(--border); transition: transform 0.3s ease;">
          <% if (item.image) { %>
            <img src="<%= item.image %>" alt="<%= item.title %>" style="width: 100%; height: 250px; object-fit: cover; display: block;">
          <% } %>
          <div style="padding: 1rem; text-align: center; background: var(--bg);">
            <h3 style="margin: 0; font-size: 1.1rem; color: var(--text);"><%= item.title %></h3>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <p style="color: var(--text-muted);">No photos in the gallery yet.</p>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
