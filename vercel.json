{
    "version": 2,
    "builds": [
        {
            "src": "backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/frontend/public/assets/$1"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "/frontend/public/uploads/$1"
        },
        {
            "src": "/(.*)",
            "dest": "backend/server.js"
        }
    ]
}